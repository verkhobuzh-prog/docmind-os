# App
APP_NAME=DocMind OS
APP_VERSION=0.1.0
ENVIRONMENT=development
API_DEBUG=true
LOG_LEVEL=INFO
LOG_JSON=true
AUTH_DISABLED=false

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend (Vite — also set in frontend/.env)
VITE_SUPABASE_URL=${SUPABASE_URL}
VITE_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}
VITE_API_URL=http://localhost:8000
FRONTEND_PORT=5173

# Supabase (production auth + optional cloud DB)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=documents
SUPABASE_SIGNED_URL_EXPIRES=3600

# Local data layer (Docker Compose)
DATABASE_URL=postgresql://docmind:docmind@localhost:5432/docmind
REDIS_URL=redis://localhost:6379/0
POSTGRES_PORT=5432
REDIS_PORT=6379

# ============================================================
# GRAPH DB (FalkorDB) — Phase 2
# ============================================================
GRAPH_DB_URL=redis://localhost:6380
GRAPH_DB_NAME=docmind_knowledge
GRAPH_DB_ENABLED=false

# ============================================================
# INGESTION 2.0 — Triple Extraction
# ============================================================
TRIPLE_EXTRACTION_ENABLED=false
TRIPLE_EXTRACTION_MODEL=gpt-4o-mini
CONFIDENCE_THRESHOLD=0.6

# ============================================================
# PROVENANCE
# ============================================================
PROVENANCE_ENABLED=true

# ============================================================
# EXTENDED PARSERS — Phase 2
# ============================================================
AUDIO_TRANSCRIPTION_ENABLED=false
MAX_DOCUMENT_SIZE_MB=25
MAX_AUDIO_SIZE_MB=100

# AI (Phase 1+)
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=1536
DEFAULT_LLM_MODEL=gpt-4o-mini

# Ingestion
INGESTION_CHUNK_SIZE=512
INGESTION_CHUNK_OVERLAP=64
INGESTION_AUTO_START=true

# RAG / Chat
RAG_TOP_K=8
RAG_VECTOR_WEIGHT=0.7
RAG_MAX_CONTEXT_CHARS=12000

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# Personal pilot
PILOT_INVITE_REQUIRED=true
PILOT_ADMIN_EMAILS=your@gmail.com
FRONTEND_URL=http://localhost:5173
